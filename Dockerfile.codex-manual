FROM node:22-bookworm-slim

ARG CODEX_VERSION=0.116.0

ENV DEBIAN_FRONTEND=noninteractive
ENV TERM=xterm-256color
ENV CODEX_HOME=/codex-home

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        bubblewrap \
        build-essential \
        ca-certificates \
        coreutils \
        curl \
        fd-find \
        file \
        findutils \
        gawk \
        git \
        grep \
        jq \
        less \
        make \
        openssh-client \
        patch \
        pkg-config \
        procps \
        python-is-python3 \
        python3 \
        python3-pip \
        python3-venv \
        ripgrep \
        sed \
        sqlite3 \
        tmux \
        unzip \
        wget \
        xz-utils \
        zip \
    && ln -sf /usr/bin/fdfind /usr/local/bin/fd \
    && python3 -m pip install --no-cache-dir --break-system-packages uv \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g "@openai/codex@${CODEX_VERSION}"

COPY scripts/docker/manual-entrypoint.sh /usr/local/bin/mythicmcp-codex-entrypoint
RUN chmod +x /usr/local/bin/mythicmcp-codex-entrypoint

WORKDIR /workspace

ENTRYPOINT ["/usr/local/bin/mythicmcp-codex-entrypoint"]
CMD ["codex"]
